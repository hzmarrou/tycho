.env
output/
# Per-domain knowledge bases. The tutorial creates domains/npl/ inside
# the cloned repo; ignore so tester-generated artifacts (extraction
# JSONs, fused dictionaries, log.md, filed-back analyses) don't show
# up as untracked files in `git status`.
domains/
__pycache__/
*.pyc
*.pyo
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/
*.owl.bak
*.rdf.bak
.mypy_cache/

# Third-party reference material kept locally for reading but not
# redistributed via git (potential license / copyright concerns).
docs/guidance_on_npl.en.md
docs/guidance_on_npl.en.pdf
docs/technical-report-kaprthy+.md
# Validation source documents (regulator-published, copyrighted, large).
docs/ESG/

# Default Excel output written by ``ontozense extract-a`` to the cwd
# when --output isn't specified. Tests-only side-effect.
source-a-extraction.xlsx
